#include "stm32h5xx_ll_bus.h"
#include "stm32h5xx_ll_gpio.h"
#include "stm32h5xx_ll_utils.h"
#include "nhd0420_i2c.h"
#include "DDR5_Board.h"

volatile uint32_t g_ms_ticks = 0;

void SysTick_Handler(void)
{
    g_ms_ticks++;
}

static inline void delay_ms(uint32_t ms)
{
    uint32_t start = g_ms_ticks;
    while ((g_ms_ticks - start) < ms) { }
}

static nhd0420_t g_lcd;

int main(void)
{
    int rc;
    uint8_t clear_cmd[2] = {0xFE, 0x51};

    DDR5_Clock_Init();
    DDR5_GPIO_Init();
    DDR5_I2C1_Init();
    DDR5_I2C_Scan(I2C1);
    DDR5_UART_Init_115200_8N1(USART3, 64000000U);

    DDR5_UART_WriteString(USART3, "START\r\n", 100000U);

    delay_ms(200);

    rc = DDR5_I2C_WriteRaw(I2C1, 0x28U, clear_cmd, 2);
    if (rc == 0)
        DDR5_UART_WriteString(USART3, "RAW CLEAR OK\r\n", 100000U);
    else
        DDR5_UART_WriteString(USART3, "RAW CLEAR FAIL\r\n", 100000U);

    rc = nhd0420_init(&g_lcd, I2C1, 0x28U, delay_ms);
    if (rc == 0)
    {
        DDR5_UART_WriteString(USART3, "LCD INIT OK\r\n", 100000U);

        nhd0420_set_backlight(&g_lcd, 8U);
        nhd0420_set_contrast(&g_lcd, 40U);
        nhd0420_clear(&g_lcd);
        nhd0420_home(&g_lcd);
        nhd0420_write_string(&g_lcd, "HOLA");

        DDR5_UART_WriteString(USART3, "WRITE HOLA OK\r\n", 100000U);
    }
    else
    {
        DDR5_UART_WriteString(USART3, "LCD INIT FAIL\r\n", 100000U);
    }

    while (1)
    {
        LED_STOP_ON();
        delay_ms(500);
        LED_STOP_OFF();
        delay_ms(500);
    }
}
