/*
 * Clock plan
 * ----------
 * HSI = 64 MHz
 *
 * PLL1 -> SYSCLK = 125 MHz
 * PLL3 -> I3C1 kernel clock = 125 MHz
 *
 * I2C1  kernel clock = HSI
 * USART3 kernel clock = HSI
 */

#define DDR5_HSI_FREQ_HZ          64000000UL
#define DDR5_SYSCLK_FREQ_HZ       125000000UL

/* PLL1: 64 / 4 = 16 MHz, 16 * 125 = 2000 MHz, 2000 / 16 = 125 MHz */
#define DDR5_PLL1_M               4U
#define DDR5_PLL1_N               16U
#define DDR5_PLL1_P               2U
#define DDR5_PLL1_Q               2U
#define DDR5_PLL1_R               2U

/* PLL3: same as PLL1, dedicated to I3C1 */
#define DDR5_PLL3_M               4U
#define DDR5_PLL3_N               10U
#define DDR5_PLL3_P               2U
#define DDR5_PLL3_Q               2U
#define DDR5_PLL3_R               2U

static void DDR5_Clock_SetVoltageScale(void)
{


    /*
     * VOS1 for comfortable margin at 125 MHz.
     * Verify enum name against your installed CubeH5 LL version if needed.
     */
    LL_PWR_SetRegulVoltageScaling(LL_PWR_REGU_VOLTAGE_SCALE2);

    while (LL_PWR_IsActiveFlag_VOS() == 0U)
    {
    }
}

static void DDR5_Clock_SetFlashLatency(void)
{
    /*
     * Conservative for 125 MHz bring-up.
     * If your Cube/part requires a different latency, adjust here.
     */
    LL_FLASH_SetLatency(LL_FLASH_LATENCY_4);

    while (LL_FLASH_GetLatency() != LL_FLASH_LATENCY_4)
    {
    }
}

static void DDR5_Clock_InitSafeHSI(void)
{
    /* Enable HSI */
    LL_RCC_HSI_Enable();
    while (LL_RCC_HSI_IsReady() != 1U)
    {
    }

    /* Use HSI as SYSCLK */
    LL_RCC_SetSysClkSource(LL_RCC_SYS_CLKSOURCE_HSI);
    while (LL_RCC_GetSysClkSource() != LL_RCC_SYS_CLKSOURCE_STATUS_HSI)
    {
    }

    /* Safe prescalers */
    LL_RCC_SetAHBPrescaler(LL_RCC_SYSCLK_DIV_1);
    LL_RCC_SetAPB1Prescaler(LL_RCC_APB1_DIV_1);
    LL_RCC_SetAPB2Prescaler(LL_RCC_APB2_DIV_1);
    LL_RCC_SetAPB3Prescaler(LL_RCC_APB3_DIV_1);

    uint32_t SystemCoreClock = DDR5_HSI_FREQ_HZ;
    SysTick_Config(SystemCoreClock / 1000U);

}

static void DDR5_PLL1_Config(void)
{
    if (LL_RCC_PLL1_IsReady() != 0U)
    {
        LL_RCC_PLL1_Disable();
        while (LL_RCC_PLL1_IsReady() != 0U)
        {
        }
    }

    LL_RCC_PLL1_SetSource(LL_RCC_PLL1SOURCE_HSI);

    LL_RCC_PLL1_SetM(DDR5_PLL1_M);
    LL_RCC_PLL1_SetN(DDR5_PLL1_N);
    LL_RCC_PLL1_SetP(DDR5_PLL1_P);
    LL_RCC_PLL1_SetQ(DDR5_PLL1_Q);
    LL_RCC_PLL1_SetR(DDR5_PLL1_R);

    LL_RCC_PLL1_SetVCOInputRange(LL_RCC_PLLINPUTRANGE_8_16);
    LL_RCC_PLL1_SetVCOOutputRange(LL_RCC_PLLVCORANGE_WIDE);

    LL_RCC_PLL1FRACN_Disable();

    LL_RCC_PLL1P_Enable();
    LL_RCC_PLL1Q_Enable();
    LL_RCC_PLL1R_Enable();

    LL_RCC_PLL1_Enable();
    while (LL_RCC_PLL1_IsReady() != 1U)
    {
    }
}

static void DDR5_PLL3_Config(void)
{
    if (LL_RCC_PLL3_IsReady() != 0U)
    {
        LL_RCC_PLL3_Disable();
        while (LL_RCC_PLL3_IsReady() != 0U)
        {
        }
    }

    LL_RCC_PLL3_SetSource(LL_RCC_PLL3SOURCE_HSI);

    LL_RCC_PLL3_SetM(DDR5_PLL3_M);
    LL_RCC_PLL3_SetN(DDR5_PLL3_N);
    LL_RCC_PLL3_SetP(DDR5_PLL3_P);
    LL_RCC_PLL3_SetQ(DDR5_PLL3_Q);
    LL_RCC_PLL3_SetR(DDR5_PLL3_R);

    LL_RCC_PLL3_SetVCOInputRange(LL_RCC_PLLINPUTRANGE_8_16);
    LL_RCC_PLL3_SetVCOOutputRange(LL_RCC_PLLVCORANGE_WIDE);

    LL_RCC_PLL3FRACN_Disable();

    LL_RCC_PLL3P_Disable();
    LL_RCC_PLL3Q_Disable();
    LL_RCC_PLL3R_Enable();

    LL_RCC_PLL3_Enable();
    while (LL_RCC_PLL3_IsReady() != 1U)
    {
    }
}

void Debug_ReadClockTree(void)
{
    /* Para que el compilador no las optimice y puedas verlas en debug */
    volatile uint32_t reg_cr        = RCC->CR;
    volatile uint32_t reg_cfgr1     = RCC->CFGR1;
    volatile uint32_t reg_cfgr2     = RCC->CFGR2;
    volatile uint32_t reg_pll1cfgr  = RCC->PLL1CFGR;
    volatile uint32_t reg_pll1divr  = RCC->PLL1DIVR;
    volatile uint32_t reg_pll1fracr = RCC->PLL1FRACR;
    volatile uint32_t reg_pll2cfgr  = RCC->PLL2CFGR;
    volatile uint32_t reg_pll2divr  = RCC->PLL2DIVR;
    volatile uint32_t reg_pll2fracr = RCC->PLL2FRACR;
    volatile uint32_t reg_pll3cfgr  = RCC->PLL3CFGR;
    volatile uint32_t reg_pll3divr  = RCC->PLL3DIVR;
    volatile uint32_t reg_pll3fracr = RCC->PLL3FRACR;

    /* Frecuencias base nominales del datasheet */
    volatile double hse_hz   = 8000000.0;   /* AJÚSTALA a tu cristal real */
    volatile double hsi_nom  = 64000000.0;  /* DS: HSI = 64 MHz */
    volatile double csi_hz   = 4000000.0;   /* DS: CSI = 4 MHz */
    volatile double hsi48_hz = 48000000.0;  /* DS: HSI48 = 48 MHz */
    volatile double lsi_hz   = 32000.0;
    volatile double lse_hz   = 32768.0;

    /* ---------- HSI efectivo ---------- */
    /* En STM32H5 el HSI puede dividirse por HSIDIV */
    volatile uint32_t hsidiv_bits = (reg_cr >> RCC_CR_HSIDIV_Pos) & 0x3U;
    volatile uint32_t hsi_divider = 1U;

    switch (hsidiv_bits)
    {
        case 0U: hsi_divider = 1U; break;
        case 1U: hsi_divider = 2U; break;
        case 2U: hsi_divider = 4U; break;
        case 3U: hsi_divider = 8U; break;
        default: hsi_divider = 1U; break;
    }

    volatile double hsi_hz = hsi_nom / (double)hsi_divider;

    /* ---------- Prescalers AHB/APB ---------- */
    volatile uint32_t hpre_bits  = (reg_cfgr2 >> RCC_CFGR2_HPRE_Pos)  & 0xFU;
    volatile uint32_t ppre1_bits = (reg_cfgr2 >> RCC_CFGR2_PPRE1_Pos) & 0x7U;
    volatile uint32_t ppre2_bits = (reg_cfgr2 >> RCC_CFGR2_PPRE2_Pos) & 0x7U;
    volatile uint32_t ppre3_bits = (reg_cfgr2 >> RCC_CFGR2_PPRE3_Pos) & 0x7U;

    volatile uint32_t hpre_div  = 1U;
    volatile uint32_t ppre1_div = 1U;
    volatile uint32_t ppre2_div = 1U;
    volatile uint32_t ppre3_div = 1U;

    switch (hpre_bits)
    {
        case 0x0: case 0x1: case 0x2: case 0x3:
        case 0x4: case 0x5: case 0x6: case 0x7: hpre_div = 1U;   break;
        case 0x8: hpre_div = 2U;   break;
        case 0x9: hpre_div = 4U;   break;
        case 0xA: hpre_div = 8U;   break;
        case 0xB: hpre_div = 16U;  break;
        case 0xC: hpre_div = 64U;  break;
        case 0xD: hpre_div = 128U; break;
        case 0xE: hpre_div = 256U; break;
        case 0xF: hpre_div = 512U; break;
        default:  hpre_div = 1U;   break;
    }

    switch (ppre1_bits)
    {
        case 0x0: case 0x1: case 0x2: case 0x3: ppre1_div = 1U;  break;
        case 0x4: ppre1_div = 2U;  break;
        case 0x5: ppre1_div = 4U;  break;
        case 0x6: ppre1_div = 8U;  break;
        case 0x7: ppre1_div = 16U; break;
        default:  ppre1_div = 1U;  break;
    }

    switch (ppre2_bits)
    {
        case 0x0: case 0x1: case 0x2: case 0x3: ppre2_div = 1U;  break;
        case 0x4: ppre2_div = 2U;  break;
        case 0x5: ppre2_div = 4U;  break;
        case 0x6: ppre2_div = 8U;  break;
        case 0x7: ppre2_div = 16U; break;
        default:  ppre2_div = 1U;  break;
    }

    switch (ppre3_bits)
    {
        case 0x0: case 0x1: case 0x2: case 0x3: ppre3_div = 1U;  break;
        case 0x4: ppre3_div = 2U;  break;
        case 0x5: ppre3_div = 4U;  break;
        case 0x6: ppre3_div = 8U;  break;
        case 0x7: ppre3_div = 16U; break;
        default:  ppre3_div = 1U;  break;
    }

    /* ---------- Estado fuente SYSCLK ---------- */
    volatile uint32_t sw_bits  = (reg_cfgr1 >> RCC_CFGR1_SW_Pos)  & 0x3U;
    volatile uint32_t sws_bits = (reg_cfgr1 >> RCC_CFGR1_SWS_Pos) & 0x3U;

    /* ---------- Helper local para PLLx ---------- */
    volatile double pll1_src_hz = 0.0, pll2_src_hz = 0.0, pll3_src_hz = 0.0;
    volatile double pll1_ref_hz = 0.0, pll2_ref_hz = 0.0, pll3_ref_hz = 0.0;
    volatile double pll1_vco_hz = 0.0, pll2_vco_hz = 0.0, pll3_vco_hz = 0.0;
    volatile double pll1_p_hz   = 0.0, pll1_q_hz   = 0.0, pll1_r_hz   = 0.0;
    volatile double pll2_p_hz   = 0.0, pll2_q_hz   = 0.0, pll2_r_hz   = 0.0;
    volatile double pll3_p_hz   = 0.0, pll3_q_hz   = 0.0, pll3_r_hz   = 0.0;

    volatile uint32_t pll1_on   = (reg_cr >> RCC_CR_PLL1ON_Pos)  & 0x1U;
    volatile uint32_t pll1_rdy  = (reg_cr >> RCC_CR_PLL1RDY_Pos) & 0x1U;
    volatile uint32_t pll2_on   = (reg_cr >> RCC_CR_PLL2ON_Pos)  & 0x1U;
    volatile uint32_t pll2_rdy  = (reg_cr >> RCC_CR_PLL2RDY_Pos) & 0x1U;
    volatile uint32_t pll3_on   = (reg_cr >> RCC_CR_PLL3ON_Pos)  & 0x1U;
    volatile uint32_t pll3_rdy  = (reg_cr >> RCC_CR_PLL3RDY_Pos) & 0x1U;

    /* ---------- PLL1 ---------- */
    {
        volatile uint32_t pllsrc   = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1SRC_Pos)   & 0x3U;
        volatile uint32_t m_raw    = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1M_Pos)      & 0x3FU;
        volatile uint32_t n_raw    = (reg_pll1divr  >> RCC_PLL1DIVR_PLL1N_Pos)      & 0x1FFU;
        volatile uint32_t p_raw    = (reg_pll1divr  >> RCC_PLL1DIVR_PLL1P_Pos)      & 0x7FU;
        volatile uint32_t q_raw    = (reg_pll1divr  >> RCC_PLL1DIVR_PLL1Q_Pos)      & 0x7FU;
        volatile uint32_t r_raw    = (reg_pll1divr  >> RCC_PLL1DIVR_PLL1R_Pos)      & 0x7FU;
        volatile uint32_t fracn    = (reg_pll1fracr >> RCC_PLL1FRACR_PLL1FRACN_Pos) & 0x1FFFU;
        volatile uint32_t fracen   = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1FRACEN_Pos) & 0x1U;
        volatile uint32_t pen      = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1PEN_Pos)    & 0x1U;
        volatile uint32_t qen      = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1QEN_Pos)    & 0x1U;
        volatile uint32_t ren      = (reg_pll1cfgr  >> RCC_PLL1CFGR_PLL1REN_Pos)    & 0x1U;

        volatile uint32_t M = m_raw;
        volatile uint32_t N = n_raw;
        volatile uint32_t P = p_raw + 1U;
        volatile uint32_t Q = q_raw + 1U;
        volatile uint32_t R = r_raw + 1U;

        switch (pllsrc)
        {
            case 1U: pll1_src_hz = hsi_hz; break;
            case 2U: pll1_src_hz = csi_hz; break;
            case 3U: pll1_src_hz = hse_hz; break;
            default: pll1_src_hz = 0.0;    break;
        }

        if ((pll1_on || pll1_rdy) && (M != 0U) && (pll1_src_hz > 0.0))
        {
            pll1_ref_hz = pll1_src_hz / (double)M;

            if (fracen)
                pll1_vco_hz = pll1_ref_hz * ((double)N + ((double)fracn / 8192.0));
            else
                pll1_vco_hz = pll1_ref_hz * (double)N;

            if (pen && (P != 0U)) pll1_p_hz = pll1_vco_hz / (double)P;
            if (qen && (Q != 0U)) pll1_q_hz = pll1_vco_hz / (double)Q;
            if (ren && (R != 0U)) pll1_r_hz = pll1_vco_hz / (double)R;
        }
    }

    /* ---------- PLL2 ---------- */
    {
        volatile uint32_t pllsrc   = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2SRC_Pos)   & 0x3U;
        volatile uint32_t m_raw    = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2M_Pos)      & 0x3FU;
        volatile uint32_t n_raw    = (reg_pll2divr  >> RCC_PLL2DIVR_PLL2N_Pos)      & 0x1FFU;
        volatile uint32_t p_raw    = (reg_pll2divr  >> RCC_PLL2DIVR_PLL2P_Pos)      & 0x7FU;
        volatile uint32_t q_raw    = (reg_pll2divr  >> RCC_PLL2DIVR_PLL2Q_Pos)      & 0x7FU;
        volatile uint32_t r_raw    = (reg_pll2divr  >> RCC_PLL2DIVR_PLL2R_Pos)      & 0x7FU;
        volatile uint32_t fracn    = (reg_pll2fracr >> RCC_PLL2FRACR_PLL2FRACN_Pos) & 0x1FFFU;
        volatile uint32_t fracen   = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2FRACEN_Pos) & 0x1U;
        volatile uint32_t pen      = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2PEN_Pos)    & 0x1U;
        volatile uint32_t qen      = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2QEN_Pos)    & 0x1U;
        volatile uint32_t ren      = (reg_pll2cfgr  >> RCC_PLL2CFGR_PLL2REN_Pos)    & 0x1U;

        volatile uint32_t M = m_raw;
        volatile uint32_t N = n_raw;
        volatile uint32_t P = p_raw + 1U;
        volatile uint32_t Q = q_raw + 1U;
        volatile uint32_t R = r_raw + 1U;

        switch (pllsrc)
        {
            case 1U: pll2_src_hz = hsi_hz; break;
            case 2U: pll2_src_hz = csi_hz; break;
            case 3U: pll2_src_hz = hse_hz; break;
            default: pll2_src_hz = 0.0;    break;
        }

        if ((pll2_on || pll2_rdy) && (M != 0U) && (pll2_src_hz > 0.0))
        {
            pll2_ref_hz = pll2_src_hz / (double)M;

            if (fracen)
                pll2_vco_hz = pll2_ref_hz * ((double)N + ((double)fracn / 8192.0));
            else
                pll2_vco_hz = pll2_ref_hz * (double)N;

            if (pen && (P != 0U)) pll2_p_hz = pll2_vco_hz / (double)P;
            if (qen && (Q != 0U)) pll2_q_hz = pll2_vco_hz / (double)Q;
            if (ren && (R != 0U)) pll2_r_hz = pll2_vco_hz / (double)R;
        }
    }

    /* ---------- PLL3 ---------- */
    {
        volatile uint32_t pllsrc   = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3SRC_Pos)   & 0x3U;
        volatile uint32_t m_raw    = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3M_Pos)      & 0x3FU;
        volatile uint32_t n_raw    = (reg_pll3divr  >> RCC_PLL3DIVR_PLL3N_Pos)      & 0x1FFU;
        volatile uint32_t p_raw    = (reg_pll3divr  >> RCC_PLL3DIVR_PLL3P_Pos)      & 0x7FU;
        volatile uint32_t q_raw    = (reg_pll3divr  >> RCC_PLL3DIVR_PLL3Q_Pos)      & 0x7FU;
        volatile uint32_t r_raw    = (reg_pll3divr  >> RCC_PLL3DIVR_PLL3R_Pos)      & 0x7FU;
        volatile uint32_t fracn    = (reg_pll3fracr >> RCC_PLL3FRACR_PLL3FRACN_Pos) & 0x1FFFU;
        volatile uint32_t fracen   = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3FRACEN_Pos) & 0x1U;
        volatile uint32_t pen      = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3PEN_Pos)    & 0x1U;
        volatile uint32_t qen      = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3QEN_Pos)    & 0x1U;
        volatile uint32_t ren      = (reg_pll3cfgr  >> RCC_PLL3CFGR_PLL3REN_Pos)    & 0x1U;

        volatile uint32_t M = m_raw;
        volatile uint32_t N = n_raw;
        volatile uint32_t P = p_raw + 1U;
        volatile uint32_t Q = q_raw + 1U;
        volatile uint32_t R = r_raw + 1U;

        switch (pllsrc)
        {
            case 1U: pll3_src_hz = hsi_hz; break;
            case 2U: pll3_src_hz = csi_hz; break;
            case 3U: pll3_src_hz = hse_hz; break;
            default: pll3_src_hz = 0.0;    break;
        }

        if ((pll3_on || pll3_rdy) && (M != 0U) && (pll3_src_hz > 0.0))
        {
            pll3_ref_hz = pll3_src_hz / (double)M;

            if (fracen)
                pll3_vco_hz = pll3_ref_hz * ((double)N + ((double)fracn / 8192.0));
            else
                pll3_vco_hz = pll3_ref_hz * (double)N;

            if (pen && (P != 0U)) pll3_p_hz = pll3_vco_hz / (double)P;
            if (qen && (Q != 0U)) pll3_q_hz = pll3_vco_hz / (double)Q;
            if (ren && (R != 0U)) pll3_r_hz = pll3_vco_hz / (double)R;
        }
    }

    /* ---------- SYSCLK / HCLK / PCLKx ---------- */
    volatile double sysclk_hz = 0.0;

    switch (sws_bits)
    {
        case 0U: sysclk_hz = hsi_hz;   break; /* HSI */
        case 1U: sysclk_hz = csi_hz;   break; /* CSI */
        case 2U: sysclk_hz = hse_hz;   break; /* HSE */
        case 3U: sysclk_hz = pll1_p_hz; break; /* PLL1_P según RM */
        default: sysclk_hz = 0.0;      break;
    }

    volatile double hclk_hz  = sysclk_hz / (double)hpre_div;
    volatile double pclk1_hz = hclk_hz   / (double)ppre1_div;
    volatile double pclk2_hz = hclk_hz   / (double)ppre2_div;
    volatile double pclk3_hz = hclk_hz   / (double)ppre3_div;

    /* Opcional: clocks de timer */
    volatile double tim_pclk1_hz = (ppre1_div == 1U) ? pclk1_hz : (2.0 * pclk1_hz);
    volatile double tim_pclk2_hz = (ppre2_div == 1U) ? pclk2_hz : (2.0 * pclk2_hz);
    volatile double tim_pclk3_hz = (ppre3_div == 1U) ? pclk3_hz : (2.0 * pclk3_hz);

    /* Para que el compilador no “limpie” nada incluso en builds agresivos */
    __asm volatile("" ::: "memory");
}

void DDR5_Clock_Init(void)
{
    DDR5_Clock_InitSafeHSI();

    DDR5_Clock_SetVoltageScale();
    DDR5_Clock_SetFlashLatency();

    DDR5_PLL1_Config();
    DDR5_PLL3_Config();

    /* Main bus prescalers */
    LL_RCC_SetAHBPrescaler(LL_RCC_SYSCLK_DIV_1);
    LL_RCC_SetAPB1Prescaler(LL_RCC_APB1_DIV_1);
    LL_RCC_SetAPB2Prescaler(LL_RCC_APB2_DIV_1);
    LL_RCC_SetAPB3Prescaler(LL_RCC_APB3_DIV_1);

    /* Peripheral kernel clocks
     *
     * NOTE:
     * These LL macro names can vary slightly between CubeH5 versions.
     * If any name fails, check stm32h5xx_ll_rcc.h and adjust.
     */
    //LL_RCC_SetI3CClockSource(LL_RCC_I3C1_CLKSOURCE_PLL3R);
    //LL_RCC_SetI2CClockSource(LL_RCC_I2C1_CLKSOURCE_HSI);

    /* SYSCLK <- PLL1 */
    LL_RCC_SetSysClkSource(LL_RCC_SYS_CLKSOURCE_PLL1);
    while (LL_RCC_GetSysClkSource() != LL_RCC_SYS_CLKSOURCE_STATUS_PLL1)
    {
    }

    uint32_t SystemCoreClock = DDR5_SYSCLK_FREQ_HZ;
    SysTick_Config(DDR5_SYSCLK_FREQ_HZ / 1000U);

}
