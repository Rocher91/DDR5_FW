#include "stm32h5xx_ll_bus.h"
#include "stm32h5xx_ll_gpio.h"
#include "DDR5_Board.h"


int main(void)
{
    DDR5_Clock_Init();
    Debug_Clocks_And_Flash();

    DDR5_GPIO_Init();
    DDR5_Debug_Enable_MCO_PA8( ENABLE , HSI_CLK_SEL ); // 1: PLL1_CLK_SEL (PA8 = 16 MHz) 2:HSI_CLK_SEL (PA8 = 8 MHz)
    //DDR5_EXTI_Init();
    //DDR5_IRQ_Init();

    LED_PASS_ON();
    LED_FAIL_ON();
    LED_RUN_ON();
    LED_STOP_ON();

    PWR_ENABLE_0_ON();
    PWR_ENABLE_1_ON();
    PWR_ENABLE_2_ON();
    PWR_ENABLE_3_ON();
    PWR_ENABLE_4_ON();
    PWR_ENABLE_5_ON();
    PWR_ENABLE_6_ON();
    PWR_ENABLE_7_ON();

    PWR_GOOD_6_ON();
    PWR_GOOD_7_ON();

    AUX_0_ON();
    AUX_1_ON();

    TRIG_IN_ON();
    TRIG_OUT_ON();

    while (1)
    {
    	volatile uint8_t up_btn     =  DDR5_UPButtonPressed();
		volatile uint8_t down_btn   =  DDR5_DOWNButtonPressed();
		volatile uint8_t left_btn   =  DDR5_LEFTButtonPressed();
		volatile uint8_t right_btn  =  DDR5_RIGHTButtonPressed();
		volatile uint8_t ok_btn     =  DDR5_OKButtonPressed();
		volatile uint8_t cancel_btn =  DDR5_CANCELButtonPressed();

		if (up_btn)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();

		if (down_btn)
			PWR_GOOD_1_ON();
		else
			PWR_GOOD_1_OFF();

		if (left_btn)
			PWR_GOOD_2_ON();
		else
			PWR_GOOD_2_OFF();

		if (right_btn)
			PWR_GOOD_3_ON();
		else
			PWR_GOOD_3_OFF();

		if (ok_btn)
			PWR_GOOD_4_ON();
		else
			PWR_GOOD_4_OFF();

		if (cancel_btn)
			PWR_GOOD_5_ON();
		else
			PWR_GOOD_5_OFF();

    }
}
