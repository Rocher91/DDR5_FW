#include "stm32h5xx_ll_bus.h"
#include "stm32h5xx_ll_gpio.h"
#include "DDR5_Board.h"


int main(void)
{
    DDR5_Clock_Init();
    Debug_Clocks_And_Flash();

    DDR5_GPIO_Init();
    DDR5_Debug_Enable_MCO_PA8( ENABLE , HSI_CLK_SEL ); // 1: PLL1_CLK_SEL (PA8 = 16 MHz) 2:HSI_CLK_SEL (PA8 = 8 MHz)
    //DDR5_EXTI_Init();
    //DDR5_IRQ_Init();

    LED_PASS_ON();
    LED_FAIL_ON();
    LED_RUN_ON();
    LED_STOP_ON();

    PWR_ENABLE_0_ON();
    PWR_ENABLE_1_ON();
    PWR_ENABLE_2_ON();
    PWR_ENABLE_3_ON();
    PWR_ENABLE_4_ON();
    PWR_ENABLE_5_ON();
    PWR_ENABLE_6_ON();
    PWR_ENABLE_7_ON();

    PWR_GOOD_0_ON();
    PWR_GOOD_1_ON();
    PWR_GOOD_2_ON();
    PWR_GOOD_3_ON();
    PWR_GOOD_4_ON();
    PWR_GOOD_5_ON();
    PWR_GOOD_6_ON();
    PWR_GOOD_7_ON();

    AUX_0_ON();
    AUX_1_ON();

    TRIG_IN_ON();
    TRIG_OUT_ON();

    while (1)
    {
    	if (LL_GPIO_IsInputPinSet(BTN_UP_PORT, BTN_UP_PIN) == 0U)
    		PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();

		/* DOWN */
		if (LL_GPIO_IsInputPinSet(BTN_DOWN_PORT, BTN_DOWN_PIN) == 0U)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();
		/* LEFT */
		if (LL_GPIO_IsInputPinSet(BTN_LEFT_PORT, BTN_LEFT_PIN) == 0U)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();

		/* RIGHT */
		if (LL_GPIO_IsInputPinSet(BTN_RIGHT_PORT, BTN_RIGHT_PIN) == 0U)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();
		/* OK */
		if (LL_GPIO_IsInputPinSet(BTN_OK_PORT, BTN_OK_PIN) == 0U)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();

		/* CANCEL */
		if (LL_GPIO_IsInputPinSet(BTN_CANCEL_PORT, BTN_CANCEL_PIN) == 0U)
			PWR_GOOD_0_ON();
		else
			PWR_GOOD_0_OFF();
    }
}
