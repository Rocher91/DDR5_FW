#include "stm32h5xx_ll_bus.h"
#include "stm32h5xx_ll_gpio.h"
#include "stm32h5xx_ll_utils.h"
#include "nhd0420_i2c.h"
#include "DDR5_Board.h"

volatile uint32_t g_ms_ticks = 0;

void SysTick_Handler(void)
{
    g_ms_ticks++;
}

static inline void delay_ms(uint32_t ms)
{
    uint32_t start = g_ms_ticks;
    while ((g_ms_ticks - start) < ms);
}

static nhd0420_t g_lcd;

int main(void)
{
    DDR5_Clock_Init();
    //Debug_Clocks_And_Flash();

    DDR5_GPIO_Init();
    DDR5_I2C1_Init();
    //DDR5_Debug_Enable_MCO_PA8( ENABLE , HSI_CLK_SEL ); // 1: PLL1_CLK_SEL (PA8 = 16 MHz) 2:HSI_CLK_SEL (PA8 = 8 MHz)
    //DDR5_EXTI_Init();
    //DDR5_IRQ_Init();

    DDR5_UART_Init_115200_8N1(USART3, 64000000U);
    DDR5_UART_WriteString(USART3, BOARD_NAME , 100000U);

    delay_ms(200);

    void DDR5_I2C_Scan(&I2C1);
	//nhd0420_clear(&g_lcd);
	//nhd0420_write_string(&g_lcd, "HOLA");

    LED_PASS_ON();
    LED_FAIL_ON();

    LED_RUN_ON();

    PWR_ENABLE_0_ON();
    PWR_ENABLE_1_ON();
    PWR_ENABLE_2_ON();
    PWR_ENABLE_3_ON();
    PWR_ENABLE_4_ON();
    PWR_ENABLE_5_ON();
    PWR_ENABLE_6_ON();
    PWR_ENABLE_7_ON();

    PWR_GOOD_6_ON();
    PWR_GOOD_7_ON();


    AUX_0_ON();
    AUX_1_ON();

    TRIG_IN_ON();
    TRIG_OUT_ON();

    while (1)
    {
    	volatile uint8_t up_btn     =  DDR5_UPButtonPressed();
		volatile uint8_t down_btn   =  DDR5_DOWNButtonPressed();
		volatile uint8_t left_btn   =  DDR5_LEFTButtonPressed();
		volatile uint8_t right_btn  =  DDR5_RIGHTButtonPressed();
		volatile uint8_t ok_btn     =  DDR5_OKButtonPressed();
		volatile uint8_t cancel_btn =  DDR5_CANCELButtonPressed();

		if (up_btn)
		{
			PWR_GOOD_0_ON();
			DDR5_UART_WriteString(USART3, "Button Up Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_0_OFF();

		if (down_btn)
		{
			PWR_GOOD_1_ON();
			DDR5_UART_WriteString(USART3, "Button Down Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_1_OFF();

		if (left_btn)
		{
			PWR_GOOD_2_ON();
			DDR5_UART_WriteString(USART3, "Button Left Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_2_OFF();

		if (right_btn)
		{
			PWR_GOOD_3_ON();
			DDR5_UART_WriteString(USART3, "Button Right Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_3_OFF();

		if (ok_btn)
		{
			PWR_GOOD_4_ON();
			//DDR5_UART_WriteString(USART3, "Button OK Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_4_OFF();

		if (cancel_btn)
		{
			PWR_GOOD_5_ON();
			DDR5_UART_WriteString(USART3, "BUtton Cancel Pressed\r\n", 100000U);
		}
		else
			PWR_GOOD_5_OFF();

		LED_STOP_ON();
		delay_ms(500);
		LED_STOP_OFF();
		delay_ms(500);

    }
}
